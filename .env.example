# Harness env API (the a2a-hack CLI on your host)
ENV_API_URL=http://host.docker.internal:8090
CS_AGENT_URL=http://host.docker.internal:8090/cs-agent
RESEARCH_AGENT_URL=http://host.docker.internal:8090/research-agent

# Per-service env API tokens (must match the harness's tokens; these are the
# harness dev defaults)
PERSONAL_ENV_API_TOKEN=dev-user-token
CS_ENV_API_TOKEN=dev-agent-token

# Model — gemini-3.5-flash is required (see "Models" in the README)
MODEL=gemini-3.5-flash

# Vertex AI auth: a Vertex AI *Express Mode* API key (Google Cloud console ->
# express mode -> APIs & Services > Credentials). This same key authenticates both
# your agents and the harness's simulated user (it routes the key through the Vertex
# express endpoint). A regular GCP / AI Studio API key will NOT work here.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_API_KEY=...
